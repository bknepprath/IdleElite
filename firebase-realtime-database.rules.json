== true && newData.child('deleted_at').val() == now && newData.child('deleted_by').val() == auth.uid))",
                                                                                     ".validate":  "newData.hasChildren(['sender_id', 'name', 'avatar_index', 'text', 'created_at', 'created_at_unix', 'deleted'])",
